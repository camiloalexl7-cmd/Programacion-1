#include <stdio.h>

int main(int arg, char *argv[])
{

    float cal[5][3][3];
    char nombres[5][20];
    char asignaturas[3][20] = {"Matematicas", "Fisica", "Quimica"};

    int opc = 0, opc2 = 0;
    int selA = 0;

    int contAlumnos = 0;

    float promedios[5][3] = {0};

    do
    {
        printf("seleccione una opcion\n");
        printf("1. Registrar alumno\n");
        printf("2. Registrar calificaciones\n");
        printf("3. Promedio por alumno\n");
        printf("4. promedio por asignatura\n");
        printf("5. Calificacion mas alta y mas baja por estudiante\n");
        printf("6. calificacion mas alta y mas baja por asignatura\n");
        printf("7. Estudiantes aprobados y reprobados por asignatura\n");
        printf(">> ");
        scanf("%d", &opc);

        switch (opc)
        {
        case 1:
            if (contAlumnos >= 5)
            {
                printf("[!] No se pueden registrar mas de 5 alumnos.\n");
                break;
            }
            printf("ingrese el nombre del alumno %d\n", contAlumnos + 1);
            getchar();
            fgets(nombres[contAlumnos], 20, stdin);
            // Quitar el salto de linea que deja fgets
            int len = 0;
            while (nombres[contAlumnos][len] != '\0') len++;
            if (len > 0 && nombres[contAlumnos][len - 1] == '\n')
                nombres[contAlumnos][len - 1] = '\0';
            contAlumnos++;
            break;

        case 2:
            if (contAlumnos == 0)
            {
                printf("[!] No hay alumnos registrados.\n");
                break;
            }
            printf("Seleccione el alumno del que desee registrar las calificaciones: \n");
            for (int i = 0; i < contAlumnos; i++)
            {
                printf("%d. %s\n", i + 1, nombres[i]);
            }

            printf(">> ");
            scanf("%d", &selA);

            // Validar rango
            if (selA < 1 || selA > contAlumnos)
            {
                printf("[!] Alumno invalido.\n");
                break;
            }
            selA--; // Ajustar al indice real

            for (int i = 0; i < 3; i++)
            {
                printf("Ingrese las notas de la materia: %s\n", asignaturas[i]);
                promedios[selA][i] = 0;
                for (int j = 0; j < 3; j++)
                {
                    float nota = -1;
                    while (nota < 0 || nota > 10)
                    {
                        printf("Nota %d (0-10): ", j + 1);
                        scanf("%f", &nota);
                        if (nota < 0 || nota > 10)
                            printf("[!] Nota invalida. Debe estar entre 0 y 10.\n");
                    }
                    cal[selA][i][j] = nota;
                    promedios[selA][i] += cal[selA][i][j];
                }
                promedios[selA][i] /= 3;
            }
            break;

        case 3:
            printf("--------------------Calificaciones--------------------\n");
            printf("%s\t\t%s\t\t%s\n", asignaturas[0], asignaturas[1], asignaturas[2]);

            for (int i = 0; i < contAlumnos; i++)
            {
                printf("%.2f\t\t%.2f\t\t%.2f\t\t%s\n", promedios[i][0],
                       promedios[i][1],
                       promedios[i][2],
                       nombres[i]);
            }
            break;

        case 4:
            printf("--------------------Promedio por asignatura--------------------\n");
            for (int j = 0; j < 3; j++)
            {
                float suma = 0;
                for (int i = 0; i < contAlumnos; i++)
                    suma += promedios[i][j];
                printf("%s: %.2f\n", asignaturas[j], contAlumnos > 0 ? suma / contAlumnos : 0);
            }
            break;

        case 5:
            printf("--------------------Calificacion mas alta y baja por estudiante--------------------\n");
            printf("%-20s %-12s %-12s\n", "Alumno", "Mas Alta", "Mas Baja");
            for (int i = 0; i < contAlumnos; i++)
            {
                float alta = cal[i][0][0];
                float baja = cal[i][0][0];
                for (int j = 0; j < 3; j++)
                {
                    for (int k = 0; k < 3; k++)
                    {
                        if (cal[i][j][k] > alta) alta = cal[i][j][k];
                        if (cal[i][j][k] < baja) baja = cal[i][j][k];
                    }
                }
                printf("%-20s %-12.2f %-12.2f\n", nombres[i], alta, baja);
            }
            break;

        case 6:
            printf("--------------------Calificacion mas alta y baja por asignatura--------------------\n");
            for (int j = 0; j < 3; j++)
            {
                float alta = cal[0][j][0];
                float baja = cal[0][j][0];
                int idxAlta = 0, idxBaja = 0;
                for (int i = 0; i < contAlumnos; i++)
                {
                    for (int k = 0; k < 3; k++)
                    {
                        if (cal[i][j][k] > alta) { alta = cal[i][j][k]; idxAlta = i; }
                        if (cal[i][j][k] < baja) { baja = cal[i][j][k]; idxBaja = i; }
                    }
                }
                printf("%s -> Alta: %.2f (%s) | Baja: %.2f (%s)\n",
                       asignaturas[j], alta, nombres[idxAlta], baja, nombres[idxBaja]);
            }
            break;

        case 7:
            printf("--------------------Aprobados y reprobados por asignatura--------------------\n");
            for (int j = 0; j < 3; j++)
            {
                int aprobados = 0, reprobados = 0;
                printf("\n%s:\n", asignaturas[j]);
                for (int i = 0; i < contAlumnos; i++)
                {
                    if (promedios[i][j] >= 6.0)
                    {
                        printf("  [APROBADO]  %s (%.2f)\n", nombres[i], promedios[i][j]);
                        aprobados++;
                    }
                    else
                    {
                        printf("  [REPROBADO] %s (%.2f)\n", nombres[i], promedios[i][j]);
                        reprobados++;
                    }
                }
                printf("  Aprobados: %d | Reprobados: %d\n", aprobados, reprobados);
            }
            break;
        }

        printf("Desea realizar otra operacion? 1. Si 2. No\n");
        scanf("%d", &opc2);

    } while (opc2 == 1);

    return 0;

}
